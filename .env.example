# Copy to .env and fill in. NEVER commit .env.
# Leave everything blank to run in offline demo mode (the reasoning is identical;
# only the natural-language narration differs).

# ---- Option 1: Microsoft Foundry project endpoint + Entra ID (recommended) ----
# Run `az login` first (use your own Azure account).
AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_MODEL_DEPLOYMENT=gpt-4o

# ---- Option 2: Azure OpenAI endpoint + key ----
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ---- Foundry IQ grounding (real Azure AI Search hybrid retrieval) ----
# Leave blank to ground on the local synthetic corpus instead (offline-safe).
# Build the index first: python scripts/build_foundry_iq.py
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=delphai-knowledge
AZURE_EMBED_ENDPOINT=
AZURE_EMBED_KEY=
AZURE_EMBED_DEPLOYMENT=text-embedding-3-small
AZURE_EMBED_API_VERSION=2024-08-01-preview
